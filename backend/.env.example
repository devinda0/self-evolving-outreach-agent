# LLM
GEMINI_API_KEY=your-gemini-api-key

# Search
TAVILY_API_KEY=your-tavily-api-key

# Database
MONGODB_URI=mongodb://localhost:27017
DB_NAME=signal_to_action

# Email deployment
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=outreach@yourdomain.com

# LinkedIn deployment
UNIPILE_API_KEY=your-unipile-api-key
UNIPILE_LINKEDIN_ACCOUNT_ID=your-account-id

# Dev flags
USE_MOCK_SEND=true        # set false to use real Resend/Unipile
USE_MOCK_LLM=false        # set true to bypass Gemini in tests
